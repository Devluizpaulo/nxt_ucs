
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    /**
     * REGRA GLOBAL DE AUDITORIA
     * Conforme solicitado: Se o usuário estiver autenticado, ele possui 
     * permissão total de leitura e escrita em todo o Ledger.
     */
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
  }
}
