
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * Para este protótipo de auditoria, permitimos que qualquer usuário autenticado
     * (incluindo logins anônimos automáticos) visualize e gerencie os pedidos, movimentos,
     * produtores e associações.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    match /pedidos/{pedidoId} {
      allow read, write: if isSignedIn();
      
      match /movimentos/{movimentoId} {
        allow read, write: if isSignedIn();
      }
    }
    
    match /produtores/{produtorId} {
      allow read, write: if isSignedIn();
    }
    
    match /associacoes/{associacaoId} {
      allow read, write: if isSignedIn();
    }

    match /roles_auditor/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
    }

    match /system_metadata/unique_movimento_hashes/{hashMovimento} {
      allow read: if isSignedIn();
    }
  }
}
