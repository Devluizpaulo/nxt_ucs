
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * Para este protótipo de auditoria, permitimos que qualquer usuário autenticado
     * visualize e gerencie os pedidos, movimentos, produtores e associações.
     * Utilizamos curingas recursivos {allPaths=**} para garantir que a permissão
     * de 'list' (listagem) seja aplicada corretamente a nível de coleção.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    match /pedidos/{allPaths=**} {
      allow read, write: if isSignedIn();
    }
    
    match /produtores/{allPaths=**} {
      allow read, write: if isSignedIn();
    }
    
    match /associacoes/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    match /roles_auditor/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
    }

    match /system_metadata/unique_movimento_hashes/{hashMovimento} {
      allow read: if isSignedIn();
    }
  }
}
