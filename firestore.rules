rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Regras de segurança globais para o sistema de auditoria BMV
    // Permite acesso total para qualquer usuário autenticado.
    // Garante que operações de listagem, leitura e escrita funcionem sem interrupções.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}